#!/bin/bash
# =============================================================================
# Google Workspace Agent Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS:
#
# 1. Copy this file to your user config directory:
#    cp config.sh.example ~/.config/gws-agent/config.sh
#
# 2. Edit the values below to match your preferences and environment.
#    Any line starting with '#' is a comment and will be ignored.
#
# 3. Ensure the scripts have execute permissions:
#    chmod +x ~/.config/gws-agent/config.sh
#
# 4. Run the agent scripts. They will source this configuration automatically.
#
# NOTE: Sensitive values (API keys, tokens) should be stored securely.
# Consider using environment variables or a secrets manager for production use.
#
# =============================================================================

# -----------------------------------------------------------------------------
# KNOWLEDGE BASE SETTINGS
# -----------------------------------------------------------------------------

# Path to your knowledge base directory where the agent stores learned context
# This is where the agent will read/write information about your workflows,
# preferences, and recurring patterns.
# Default: ~/knowledge-base
KNOWLEDGE_BASE_PATH=~/knowledge-base

# -----------------------------------------------------------------------------
# CALENDAR SETTINGS
# -----------------------------------------------------------------------------

# The Google Calendar ID to use for scheduling and calendar operations.
# Use 'primary' for your main calendar, or specify a calendar ID like:
#   - your-email@gmail.com (your primary calendar)
#   - team-calendar@group.calendar.google.com (shared calendar)
# Default: primary
AGENT_CALENDAR_ID=primary

# Duration in minutes for focus blocks when scheduling deep work sessions.
# Common values: 60, 90, 120
# Default: 90
FOCUS_BLOCK_DURATION=90

# Default reminder time in minutes before calendar events.
# Set to 0 to disable default reminders.
# Default: 15
DEFAULT_REMINDER=15

# Your typical working hours (24-hour format, HH:MM)
# The agent will avoid scheduling outside these hours unless necessary.
WORKING_HOURS_START=09:00
WORKING_HOURS_END=17:00

# -----------------------------------------------------------------------------
# AGENT BEHAVIOR SETTINGS
# -----------------------------------------------------------------------------

# Trust level determines how autonomous the agent can be:
#   - supervised: Agent asks for confirmation before taking action (recommended)
#   - assisted: Agent takes routine actions automatically, asks for complex ones
#   - autonomous: Agent takes most actions without confirmation (use with caution)
# Default: supervised
TRUST_LEVEL=supervised

# How often the agent should generate digest summaries of your activity:
#   - daily: Once per day (typically end of day)
#   - weekly: Once per week (typically end of week)
#   - realtime: As events occur (may be noisy)
# Default: daily
DIGEST_FREQUENCY=daily

# -----------------------------------------------------------------------------
# PRIORITY FILTERING SETTINGS
# -----------------------------------------------------------------------------

# Comma-separated list of keywords that mark items as urgent.
# Case-insensitive matching.
# Default: urgent,asap,emergency,critical
URGENT_KEYWORDS="urgent,asap,emergency,critical"

# Comma-separated list of email addresses that should always be treated as
# important. Leave empty to disable sender-based prioritization.
# Example: "boss@company.com,team-lead@company.com"
# Default: (empty)
IMPORTANT_SENDERS=""

# Comma-separated list of topics or keywords you're interested in.
# The agent will highlight emails/docs matching these topics.
# Example: "project-alpha,budget planning,Q4 roadmap"
# Default: (empty)
TOPICS_OF_INTEREST=""

# -----------------------------------------------------------------------------
# NOTIFICATION SETTINGS
# -----------------------------------------------------------------------------

# Email address to receive urgent notifications.
# Leave empty to disable email notifications.
# The agent will only use this for truly urgent items based on your filters.
# Default: (empty)
NOTIFICATION_EMAIL=""

# -----------------------------------------------------------------------------
# LOGGING SETTINGS
# -----------------------------------------------------------------------------

# Log level for agent operations:
#   - debug: Detailed diagnostic information (verbose)
#   - info: General operational messages (recommended)
#   - warn: Warning messages only
#   - error: Error messages only
# Default: info
LOG_LEVEL=info

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
# For advanced configuration options, see the agent documentation.
# =============================================================================
